{
  "name": "e-lawyer",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:all": "bash scripts/dev.sh",
    "dev:ios": "EXPO_TARGET=ios bash scripts/dev.sh",
    "dev:android": "EXPO_TARGET=android bash scripts/dev.sh",
    "dev:web": "EXPO_TARGET=web bash scripts/dev.sh",
    "dev:stop": "bash scripts/stop-dev.sh",
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "postinstall": "patch-package",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.4",
    "@hookform/resolvers": "^3.9.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/bottom-tabs": "^7.17.2",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.3.14",
    "@tanstack/react-query": "^5.51.21",
    "agora-rtm": "^2.2.4",
    "agora-token": "^2.0.5",
    "expo": "~53.0.0",
    "expo-asset": "~11.1.7",
    "expo-blur": "~14.1.4",
    "expo-constants": "~17.1.8",
    "expo-dev-client": "~5.2.4",
    "expo-font": "~13.3.1",
    "expo-image-picker": "~16.1.4",
    "expo-notifications": "~0.31.2",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-hook-form": "^7.52.1",
    "react-native": "0.79.6",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "^4.20.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/react": "~19.0.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.8.3"
  }
}
